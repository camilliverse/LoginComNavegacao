<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="#AD2C2C">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="24dp"
        android:fontFamily="@font/bungee"
        android:text="Agendar Doação"
        android:textColor="#FFFFFF"
        android:textSize="24sp"
        android:textStyle="bold" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="8dp"
        android:fontFamily="@font/montserrat_medium"
        android:text="Selecione o Hemocentro"
        android:textColor="#FDEAEA"
        android:textSize="14sp" />

    <Spinner
        android:id="@+id/spinnerHemocentro"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_marginBottom="16dp"
        android:background="#FFFFFF"
        android:padding="8dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="8dp"
        android:fontFamily="@font/montserrat_medium"
        android:text="Data"
        android:textColor="#FDEAEA"
        android:textSize="14sp" />

    <EditText
        android:id="@+id/editData"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        android:background="#FFFFFF"
        android:clickable="true"
        android:focusable="false"
        android:fontFamily="@font/montserrat_medium"
        android:hint="Selecione a data"
        android:padding="12dp"
        android:textColor="#000000"
        android:textSize="16sp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="8dp"
        android:fontFamily="@font/montserrat_medium"
        android:text="Hora"
        android:textColor="#FDEAEA"
        android:textSize="14sp" />

    <EditText
        android:id="@+id/editHora"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="24dp"
        android:background="#FFFFFF"
        android:clickable="true"
        android:focusable="false"
        android:fontFamily="@font/montserrat_medium"
        android:hint="Selecione a hora"
        android:padding="12dp"
        android:textColor="#000000"
        android:textSize="16sp" />

    <Button
        android:id="@+id/btnAgendar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        android:backgroundTint="#9B2020"
        android:fontFamily="@font/montserrat_medium"
        android:text="Agendar"
        android:textColor="#FFFFFF" />

    <Button
        android:id="@+id/btnVoltar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:backgroundTint="#5B0404"
        android:fontFamily="@font/montserrat_medium"
        android:text="Voltar"
        android:textColor="#FFFFFF" />

</LinearLayout>
